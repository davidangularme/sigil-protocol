# ═══════════════════════════════════════════════════════════════
#  SIGIL PROTOCOL — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# Your wallet private key (without 0x prefix)
PRIVATE_KEY=

# Base Sepolia RPC (free, no API key needed)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet RPC (for production deployment)
BASE_RPC_URL=https://mainnet.base.org

# BaseScan API key (optional, for contract verification)
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=

# Gas reporting (set to true to see gas costs in tests)
REPORT_GAS=false
